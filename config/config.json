{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "first-web-part-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/firstWebPart/FirstWebPartWebPart.js",
          "manifest": "./src/webparts/firstWebPart/FirstWebPartWebPart.manifest.json"
        }
      ]
    },
    "share-point-form-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/sharePointForm/SharePointFormWebPart.js",
          "manifest": "./src/webparts/sharePointForm/SharePointFormWebPart.manifest.json"
        }
      ]
    },
    "formik-validation-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/formikValidation/FormikValidationWebPart.js",
          "manifest": "./src/webparts/formikValidation/FormikValidationWebPart.manifest.json"
        }
      ]
    },
    "paginatedtable-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/paginatedtable/PaginatedtableWebPart.js",
          "manifest": "./src/webparts/paginatedtable/PaginatedtableWebPart.manifest.json"
        }
      ]
    },
    "large-list-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/largeList/LargeListWebPart.js",
          "manifest": "./src/webparts/largeList/LargeListWebPart.manifest.json"
        }
      ]
    },
    "get-allusers-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/getAllusers/GetAllusersWebPart.js",
          "manifest": "./src/webparts/getAllusers/GetAllusersWebPart.manifest.json"
        }
      ]
    },
    "graph-apikey-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/graphApikey/GraphApikeyWebPart.js",
          "manifest": "./src/webparts/graphApikey/GraphApikeyWebPart.manifest.json"
        }
      ]
    },
    "sphttpclient-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/sphttpclient/SphttpclientWebPart.js",
          "manifest": "./src/webparts/sphttpclient/SphttpclientWebPart.manifest.json"
        }
      ]
    },
    "user-profile-app-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/userProfileApp/UserProfileAppWebPart.js",
          "manifest": "./src/webparts/userProfileApp/UserProfileAppWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "FirstWebPartWebPartStrings": "lib/webparts/firstWebPart/loc/{locale}.js",
    "SharePointFormWebPartStrings": "lib/webparts/sharePointForm/loc/{locale}.js",
    "ControlStrings": "node_modules/@pnp/spfx-controls-react/lib/loc/{locale}.js",
    "FormikValidationWebPartStrings": "lib/webparts/formikValidation/loc/{locale}.js",
    "PaginatedtableWebPartStrings": "lib/webparts/paginatedtable/loc/{locale}.js",
    "LargeListWebPartStrings": "lib/webparts/largeList/loc/{locale}.js",
    "GetAllusersWebPartStrings": "lib/webparts/getAllusers/loc/{locale}.js",
    "GraphApikeyWebPartStrings": "lib/webparts/graphApikey/loc/{locale}.js",
    "SphttpclientWebPartStrings": "lib/webparts/sphttpclient/loc/{locale}.js",
    "UserProfileAppWebPartStrings": "lib/webparts/userProfileApp/loc/{locale}.js"
  }
}
